# Public HTTPS hostname (what users type in the browser), e.g. mail.example.com — must match DNS and ACME.
DOMAIN=mail.example.com
# Real mailbox for Let's Encrypt (RFC 5322). No quotes. Wrong/empty ⇒ invalidContact / no HTTPS.
ACME_EMAIL=you@example.com
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$2y$$10$$change-me
SERVER_IP=YOUR_CONTABO_IP
SMTP_HOSTNAME=mail.yourdomain.com
DATABASE_URL=postgresql+asyncpg://emailuser:password@postgres:5432/emaildb

POSTGRES_DB=emaildb
POSTGRES_USER=emailuser
POSTGRES_PASSWORD=change-this-strong-password
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=replace-with-256-bit-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_SECRET_KEY=replace-with-32-byte-base64-secret
MAILDIR_BASE=/var/mail
MAX_MESSAGE_SIZE_MB=25
DKIM_SELECTOR=mail
CLOUDFLARE_API_TOKEN=
BACKUP_PASSPHRASE=
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_HOUR=2
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change-immediately

# Super-admin "Test email" in the UI — authenticated SMTP (587), not direct MX :25
SMTP_SUBMISSION_HOST=mail.yourdomain.com
SMTP_SUBMISSION_PORT=587
SMTP_SUBMISSION_USER=admin@yourdomain.com
# Required for external relay; optional for self-hosted Nex Mail (587 stub-auth — may be empty)
SMTP_SUBMISSION_PASSWORD=
SMTP_SUBMISSION_USE_TLS=true
# If super-admin mail test times out in Docker, set to 127.0.0.1 so the API reaches this container's :587 (NAT hairpin fix).
# SMTP_SUBMISSION_CONNECT_HOST=
# Set true only if TLS verification fails (e.g. TCP host is an IP but the cert is for a hostname).
SMTP_SUBMISSION_TLS_INSECURE=false
# From header for test messages (defaults to SUPER_ADMIN_EMAIL if empty)
SMTP_TEST_MAIL_FROM=

# Fallback smarthost after direct MX :25 fails (blocked port, IP reputation, etc.). Not used as the first hop.
# Example: Brevo smtp-relay — same credentials as transactional SMTP.
SMTP_OUTBOUND_RELAY_HOST=
# 587 STARTTLS (default). If connect times out, try 2525 (many providers filter 587). For 465 use implicit TLS.
SMTP_OUTBOUND_RELAY_PORT=587
SMTP_OUTBOUND_RELAY_USER=
SMTP_OUTBOUND_RELAY_PASSWORD=
SMTP_OUTBOUND_RELAY_USE_TLS=true
# Set true when using port 465 (SMTPS). Port 465 also implies implicit TLS automatically.
SMTP_OUTBOUND_RELAY_IMPLICIT_TLS=false



FRONTEND_URL=https://mail.example.com
INVITE_BASE_URL=https://mail.example.com
NEXT_PUBLIC_API_URL=https://mail.example.com
ANTHROPIC_API_KEY=
AI_SUMMARY_ENABLED=true
AI_SMART_REPLY_ENABLED=true
AI_PRIORITY_INBOX_ENABLED=true
TRACKING_BASE_URL=https://yourdomain.com/track
TRACKING_ENABLED=true
SPAMASSASSIN_HOST=spamassassin
CLAMAV_HOST=clamav
